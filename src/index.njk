---
layout: base.njk
title: Home
---
<section class="home-intro">
  <h1>Jeffrey Pratt</h1>
  <p>Software developer. This is where I write about code, mathematics, and whatever else catches my attention.</p>
</section>

{% if collections.posts.length %}
<section class="home-recent">
  <h2>Recent posts</h2>
  <ul class="post-list">
    {% for post in collections.posts | limit(5) %}
    <li class="post-list__item">
      <div class="post-list__date">
        <time datetime="{{ post.date | dateISO }}">{{ post.date | dateDisplay }}</time>
      </div>
      <h3 class="post-list__title">
        <a href="{{ post.url }}">{{ post.data.title }}</a>
      </h3>
      {% if post.data.excerpt %}
      <p class="post-list__excerpt">{{ post.data.excerpt }}</p>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
  <p><a href="/blog/">All posts &rarr;</a></p>
</section>
{% endif %}
