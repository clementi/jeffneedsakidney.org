---
layout: base.njk
title: Blog
pagination:
  data: collections.posts
  size: 10
  alias: posts
permalink: "{% if pagination.pageNumber == 0 %}blog/{% else %}blog/page/{{ pagination.pageNumber + 1 }}/{% endif %}"
---
<h1>Blog</h1>

{% if tagList.length %}
<div class="tag-cloud">
  {% for tag in collections.tagList %}
  <a href="/blog/tags/{{ tag | slugify }}/" class="tag">{{ tag }}</a>
  {% endfor %}
</div>
{% endif %}

{% if posts.length %}
<ul class="post-list">
  {% for post in posts %}
  <li class="post-list__item">
    <div class="post-list__date">
      <time datetime="{{ post.date | dateISO }}">{{ post.date | dateDisplay }}</time>
    </div>
    <h2 class="post-list__title">
      <a href="{{ post.url }}">{{ post.data.title }}</a>
    </h2>
    {% if post.data.excerpt %}
    <p class="post-list__excerpt">{{ post.data.excerpt }}</p>
    {% endif %}
  </li>
  {% endfor %}
</ul>
{% else %}
<p>No posts yet.</p>
{% endif %}

{% if pagination.pages.length > 1 %}
<nav class="pagination" aria-label="Blog pagination">
  {% if pagination.href.previous %}
  <a href="{{ pagination.href.previous }}">&larr; Newer</a>
  {% else %}
  <span></span>
  {% endif %}
  <span class="pagination__count">Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span>
  {% if pagination.href.next %}
  <a href="{{ pagination.href.next }}">Older &rarr;</a>
  {% else %}
  <span></span>
  {% endif %}
</nav>
{% endif %}
