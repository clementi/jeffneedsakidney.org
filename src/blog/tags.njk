---
layout: base.njk
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: /blog/tags/{{ tag | slugify }}/
---
<h1>Posts tagged &ldquo;{{ tag }}&rdquo;</h1>

<ul class="post-list">
  {% set taggedPosts = collections[tag] %}
  {% for post in taggedPosts | reverse %}
  <li class="post-list__item">
    <div class="post-list__date">
      <time datetime="{{ post.date | dateISO }}">{{ post.date | dateDisplay }}</time>
    </div>
    <h2 class="post-list__title">
      <a href="{{ post.url }}">{{ post.data.title }}</a>
    </h2>
    {% if post.data.excerpt %}
    <p class="post-list__excerpt">{{ post.data.excerpt }}</p>
    {% endif %}
  </li>
  {% endfor %}
</ul>

<p><a href="/blog/">&larr; All posts</a></p>
